    mtr:llm_ratio_evidence " reaction where the ratio is shared through a pathway " ;
    mtr:llm_ratio_explanation " Reflects ACADM-mediated fatty acid oxidation efficiency; impaired function alters the balance between caproate (substrate-related) and (s)-3-hydroxybutyrylcarnitine (byproduct).[9](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHeIusLZHtCztgWHNXakRdsxOHpTZJH78M_jymx-_LurlZa8XwVa-kussRZ2rjhO-4j9r8pnU_-52_L9uYucSy-T3t2ZEEqXy4s77QjyI7OzfkRvISQNOjVfDfXojWXNh6St6Ys4rk2), [10](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQG11L4mNfvjJXua7ZFSefUvSZ4TweR9JdCbnB4zpbwxs6_c4Qtume9UjqbvSaudplCcbAu9YL-0ILK4TeIrPD_97CGB5yJvXqjikg5SmvzpSRaqzwxdYYJn2qViSH3fioN2GI28GjK2q4lL5QJyOE8dlUUyNYEHnUQ=), [4](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQFqNVg5k051yfagdKbx_r6Sh4ADQYSBUguO4fiG_nj0vVb0Yemv47t6xTpGhFXfwBgsJoNOhFGF64gKunqtJwUdqCC1m63FKQ1jVmdpO8IiWF4zQBEPi6PdJK7eQ3I0nf6EYYLpsRFh9iw2JuieGhmY19c25OkAr7He6Z6-PPKTgYKjDbMqARM9sXM0SNdhWr2kjJ6avnox2QJj97kyHgueZ311L1mYzNkkp2HPm1jKwVPMaorcRUNNSp8FViYebNf4RQOONrEeHEAcZtueUJhFwWot6Q==) " ;
    mtr:max_pgain "6.44367062890854e+21"^^xsd:float .

mtr:GCST90200246_GCST90199893 a mtr:MetaboliteRatio ;
    rdfs:label "3-hydroxydecanoylcarnitine to cis-4-decenoate (10:1n6)*" ;
    mtr:has_denominator chebi:32380 ;
    mtr:llm_gene_phenotype_relationship " Genetic variants in ACADM, a key fatty acid oxidation gene, regulate the ratio of 3-hydroxydecanoylcarnitine to cis-4-decenoate.[9](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQE5oedjA8lqdxjCLhCTrzduV-JRbIxwYt0vX39rvtTzPbtwCgFnmVdtX0_VnjOMsc75t9oynKfXVq_MSFFjwtEpxj5PvP5Yq7oXJcMcop14LqxDADTVpc9qdcYM7xix002QpAWR42O9), [10](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQE2qk2pMME-Z8f5Py8tPt_cdbQVs2hBMIuM5WhcF0IyjsuygSd4PBUj8FGOuzwqHyGTg5QgfHV3j0czWTk5Kr3aOwve0ibTV9UjRGHbu6z7He3vjyhI7ewlHmr_9j5Qg4GRga8=) No associated phenotype data was provided. " ;
    mtr:llm_phenotype_driver " none" ;
