mtr:GCST90199851_GCST90199858 a mtr:MetaboliteRatio ;
    rdfs:label "androstenediol (3beta,17beta) disulfate (2) to 5alpha-androstan-3alpha,17beta-diol monosulfate (1)" ;
    mtr:has_numerator chebi:133124 ;
    mtr:llm_gene_phenotype_relationship " Reduced GAL3ST4 activity could alter steroid sulfation, impacting levels of androgens and their metabolites, which are associated with variations in BMI and inflammatory markers like C-reactive protein.[1](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQFRloZhLzqbDRk6eKBKmvgL3RL-4DsPReEQMGMUiFBOx1HvZv4FXrnVg3_x62VDCTkBckumg8Cq8Owwt4sinFaweRTeSQbEjJ6vmr677jgsCcXl6YDZuDFNnFbH7MOd-Q==), [3](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQF4daj0P6NTaycgXS0coLrarI_leKVhqt0apiOK1u3-YpEpolkwfXf7rQT3yUFv8TckJo_2lOjWf3ArEE2tnk7Nr8ZFxrHIeksMmR2YEXaNUcz2BqhiRPbHfl3o0iXPSlZ4DNwfyTu6VnRXTPIWFV-v1U3rIi1jVUE1mkCwnX7IpdNsIXXvNw==), [5](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQF_LRsj-t9Uo8Y-tqUvQmqMET99a6ZQ0LXSndiryadv7RclaKc2YyXSsTiuGo-F-DCWRWSWP5YOoKZh-GMNZLLy9LGXkIU27cH6Exps5uT_CVqPw88B4JDqdNRaenbV0euSGN58MzCCGVQ_U74iq59c-qutLHlqiE6nYOz-Mbw33By_) " ;
    mtr:llm_phenotype_driver " Gene-centric:GAL3ST4" ;
    mtr:llm_ratio_evidence " metabolites related through biology " ;
    mtr:llm_ratio_explanation " A higher ratio may indicate decreased sulfation activity, potentially influenced by GAL3ST4, affecting the balance between mono- and disulfated androgens.[1](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQFRloZhLzqbDRk6eKBKmvgL3RL-4DsPReEQMGMUiFBOx1HvZv4FXrnVg3_x62VDCTkBckumg8Cq8Owwt4sinFaweRTeSQbEjJ6vmr677jgsCcXl6YDZuDFNnFbH7MOd-Q==), [3](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQF4daj0P6NTaycgXS0coLrarI_leKVhqt0apiOK1u3-YpEpolkwfXf7rQT3yUFv8TckJo_2lOjWf3ArEE2tnk7Nr8ZFxrHIeksMmR2YEXaNUcz2BqhiRPbHfl3o0iXPSlZ4DNwfyTu6VnRXTPIWFV-v1U3rIi1jVUE1mkCwnX7IpdNsIXXvNw==) " ;
    mtr:max_pgain "1595691504.832871"^^xsd:float .

mtr:GCST90200263_GCST90199893 a mtr:MetaboliteRatio ;
    rdfs:label "(2 or 3)-decenoate (10:1n7 or n8) to cis-4-decenoate (10:1n6)*" ;
    mtr:has_denominator chebi:32380 ;
    mtr:llm_gene_phenotype_relationship " none " ;
    mtr:llm_phenotype_driver " none" ;
    mtr:llm_ratio_evidence " reaction where the ratio is shared through a pathway " ;
    mtr:llm_ratio_explanation " This ratio reflects activity within the mitochondrial fatty acid beta-oxidation pathway; accumulation of both metabolites, especially cis-4-decenoate, is a known marker for ACADM deficiency.[14](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHSZz7WkLXAP43pPaB7Me0hpUkCUKycIYTuKoF8PK7hZ74RSyzOwBmK_8R7SCM7XlwvflhWdSWLbOGvybSS0U8cUBbN5hflLyGUdMcPoULDtU1eHDZkU-gv4o61FLYo1gZv35nBN3BWfSQv-l9JR_vVGbVr9DdZ-0TmvXya92vnwAabyWn3WTH5SNm6IXgpnFfsWIC3oBqHFcXYXCuNj_ZqSo9U08U8mXTy25peq24189XFIITq0Zyo0eO-FyFyo_b1cfwVzTEOyVq50zuR6P0e1MHTLMH2rCdWUBLPYz4c9_3zej8WkNjlL1_ah2glSrf2N4FFdo6qZpAL4WUZSh8oPpVgG7xc), [15](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQG6RsrIZGHxGfXZnxJieICbwu4uJoznCiyp4TI-_KV9zaeJzC9i_1swgZ1XFe5o1xN3VxCax-d3AyqLZvuZpEiOBMRL3LScjjxGQVKpVE6Ft-sQ5Er9yumcCNz4FPWLCj4JqR0=) " ;
    mtr:max_pgain "3.328686743146552e+48"^^xsd:float .

