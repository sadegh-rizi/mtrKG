mtr:GCST90200013_GCST90200129 a mtr:MetaboliteRatio ;
    rdfs:label "sphingomyelin (d18:1/22:2, d18:2/22:1, d16:1/24:2)* to sphingomyelin (d18:2/21:0, d16:2/23:0)*" ;
    mtr:llm_gene_phenotype_relationship " Altered FADS1 activity, supported by eQTL colocalization, changes the fatty acid composition of sphingomyelins.[2](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQF5m8F-yXiaWuINCZjqjq7SpWdxTnurlbWAW8bqm6I9jFBL35JaZNEGMsC0k1fjntzycoDa9VOA8U-dew1P78i_-J_LRSQYiKY1AD8f_UkXJLa6JgV713pvZpGNWOAXWDFJmJ6BvCo01o7VEv0h9_pipGk8oaEBy9GFTNiuisUgaSuJLshYetEI4khXXIeVdsqeuIcfjoSmeh1fanZFZ9Uki-GJEfNvjty27Mx7pf9sYQOOAdUJ3RWyn1wW8PSye_XnYQ==), [7](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHpsCufyo79IjLVUi9SxP_Dw7tLVsaY4BobaFgC3cBy__6k64voXwbE0yCzvj3Tu5zc9PC_7WYUOg2GY-5-GUVEKOxEbhZy-o57hiS-e16iWFHCxxKFmjWbU-s3yXPEjA2qSfgLuzoyqtNqYwjaWeuWWK31a5bS0t2U3w7_PXyRAmHSqTkDf17-) This dysregulation of lipid metabolism is linked to inflammatory and metabolic phenotypes like asthma, dermatitis, and hypercholesterolaemia, which show colocalization.[8](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQFoEesmZJnb0Adal_UgLm5sBoY_h55fGN8xh1RtatC_Z3cFD5aa4hsKxdQ3AIRqXiAG3DIWJlbgzXObkZMqj0J39GdOMnys3cznR0S4bVupOXyoTKjsAMPvuPDAB1NnH1rQzBtmAr1tJOUf9hQ=), [3](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQFlHoz4fIrVyQ09v5fXP89R3cHFVEDlZgGc1YTTERdUapJ6gl7NWZrPnHKgGujpFw5nxIX2DilfzV6XUaKzlLsHJcIutJ5idS9Hh6BxoytX9KZUXlqM0tnq) " ;
    mtr:llm_phenotype_driver " Gene-centric:FADS1" ;
    mtr:llm_ratio_evidence " reaction where the ratio is shared through a pathway " ;
    mtr:llm_ratio_explanation " The ratio reflects FADS1 activity, comparing sphingomyelins with more unsaturated fatty acids (numerator) to those with less unsaturated or saturated fatty acids (denominator).[1](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGr22_eTjirZ4mN4H-iVFZdVxTtmPiwz3GBEbq73sB-OMbZALDhPRc97iAz8AEp_bYd4ncac7RQZ_-hZ6KFvycNKDkWHJNjSBkk9iW_6_JuZ_MegHDmfYqdKk0JY8h5gacjwD1nOybc), [7](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHpsCufyo79IjLVUi9SxP_Dw7tLVsaY4BobaFgC3cBy__6k64voXwbE0yCzvj3Tu5zc9PC_7WYUOg2GY-5-GUVEKOxEbhZy-o57hiS-e16iWFHCxxKFmjWbU-s3yXPEjA2qSfgLuzoyqtNqYwjaWeuWWK31a5bS0t2U3w7_PXyRAmHSqTkDf17-) " ;
    mtr:max_pgain "3.647964290152924e+28"^^xsd:float .

