mtr:GCST90199873_GCST90199849 a mtr:MetaboliteRatio ;
    rdfs:label "pregnenolone sulfate to 21-hydroxypregnenolone disulfate" ;
    mtr:llm_gene_phenotype_relationship " Altered SLC17A4 function likely affects urate transport, leading to changes in serum uric acid levels.[4](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGAV3AhGxVTS7rsd4LdjEwxpGc-7HkA4uzb9hhGjLQcnwFhTXCEA7fUNs8Cc5cc3Lxuriptex1HoJ6DtO6my5hthHjDqt0TOmMn6LMZ3GfDfQt0n2USkOzF9nmuH15uuNV4kgk3d4W9YJCvbv4P1HlPhKr_Ev5VrAdgiMKR), [13](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGBQRJyHlRp5KfmCfBSaGGrVcd-L7HpeY4Yrsh3sjA69evV1MxhlKQKaRgHMn-TzoRcUwelB0qZt0R7xFFfJ9X_oyH0vVS3iP9DGBuMTchgMhtsDyYtjW70A8N_NKsKLerV2FZFJFX_ROBTTnwgIvewZV7YWBpY0V0DMb1RuA==), [15](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGqhDJBpZCocNMGkCUdYDPBJCOU3vOydT8-jEOmUn9HccmkD3iQSVYbCUKKvFnCPZfggTRCcZcmCrN4vc4V8DHnebpPKdXtFHyCWz67-ePPPW945m6N2JP-8A==) The association with hematological traits might stem from the pleiotropic effects of steroids on blood cell production or a yet-unknown role of SLC17A4 in blood cell function.[16](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQE7eH1dGbrtnCP5_KPvvP6d-9g8ih9Xxy_ukWxrbkHLf8ZBk2mI6WTKi25mxsuJtIvmqh8vC69EGpXbnBcGRtnbMlxpXVjJNZYc2XD8Fm-wbcS9m1YF6v892YgxwqrrvFkAKFrCgoNYd63uQAyLQmbkLUaRzw==), [17](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEcFqrhYHXemEI8a_0yPQYNtN4U6L_j_uSfS49O7N3veWnhEYW841-hS4fuFWGxZTL_8V-ACOisXRGkefoeBRgRsrKzBWQh8cccFGOcSV-r0A-WGgoQqXNSUp04mYCoUhkupdBeKdc=), [18](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQH9u5MBiHLlWomVuBQVY3VukxR1qNgFk5foF497reuXAYCosEV2bWUusi8D7aopTV0BAr6p5oOHNTewGCdRvMPks4fiq3vzNYBNIOArM9W6CELQBFudHwOQ5ctLrdf8JTEgm8LjLVa4Oox46vj8lygTArQ-Z5hvKi-rx8MS2m8xUeFLH-OKXg==) " ;
    mtr:llm_phenotype_driver " Gene-centric:SLC17A4" ;
    mtr:llm_ratio_evidence " metabolites related through biology " ;
    mtr:llm_ratio_explanation " The ratio of pregnenolone sulfate to its downstream metabolite 21-hydroxypregnenolone disulfate may reflect steroid metabolic activity, potentially influenced by shared transport mechanisms.[13](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGBQRJyHlRp5KfmCfBSaGGrVcd-L7HpeY4Yrsh3sjA69evV1MxhlKQKaRgHMn-TzoRcUwelB0qZt0R7xFFfJ9X_oyH0vVS3iP9DGBuMTchgMhtsDyYtjW70A8N_NKsKLerV2FZFJFX_ROBTTnwgIvewZV7YWBpY0V0DMb1RuA==), [14](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHA6tPoIf7Z9b3ZXyUxCjP62eMdnGZbfKcJ7FC21MwuiWF4mLWJCHS8lhGh7opCQhjhseZP2GJCDBDLhJqSHiXOLu9lcGcH9eT02fCdbjekMlLS5WC3qwhXUSDc97YChgo7dlc=) " ;
    mtr:max_pgain "53606769327377.01"^^xsd:float .

