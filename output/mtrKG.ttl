mtr:GCST90200033_GCST90200080 a mtr:MetaboliteRatio ;
    rdfs:label "sphingomyelin (d18:2/23:0, d18:1/23:1, d17:1/24:1)* to 1-palmitoyl-2-oleoyl-gpi (16:0/18:1)*" ;
    mtr:llm_gene_phenotype_relationship " FADS1 variants alter polyunsaturated fatty acid synthesis, affecting the ratio.[10](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQF7RH3Jl4-eNX_QLNwqohb3_oz6Zt2Qge1iL0X_tzsF00LP8vuo3tAKzEHD58JmgzHvppjEZclUz_oyufYrry7_xpSYEp4q0L8whcu9Ko7sdeCjLHcsQ5_jyZ8HtXKPLB9sZ44sbL0hlSD7yDk=), [11](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHIrs9VlLMGjYm6jGv17FYRtR3jhwxPMExf-9RQc8eSxkRcOWBMDH5yUxPZJVbc1ytV8IUahv96W74UfmKYTkdYMI6cu5BoQlcvgPjUPhHWhZ-BQyo-7e_L2dgN4THBpc0A9Pr49tFawSItrPs=) This dysregulates lipid metabolism and inflammatory pathways, contributing to phenotypes like hypercholesterolemia, cholelithiasis, and asthma, which are observed in the associated traits.[12](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGajsOXxn39hP1vrhyUIc2x5V3Vk-VAYyyJ6pvNq3oiLBwBcd5SsTnnGFK__RwYOeK4948CVE2_8XgYaML3-PJk3Zd6NfkhlI_DSvHe-14TTpUE1_5p0vpYTmq6QTIpsTSwAWtd), [11](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHIrs9VlLMGjYm6jGv17FYRtR3jhwxPMExf-9RQc8eSxkRcOWBMDH5yUxPZJVbc1ytV8IUahv96W74UfmKYTkdYMI6cu5BoQlcvgPjUPhHWhZ-BQyo-7e_L2dgN4THBpc0A9Pr49tFawSItrPs=), [13](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGp_PmSMhkbz9xatQkSoC6P6j-vgpFIsws_45JLALINEzyu7LfzeUGpcS1cKIDw0vHkH69RMx0uK1SJlFFyHQsPG5tUuO3MSXzDsCYEmQylnpg2puQGZPKv1FXf2FYp0Bg_D0RqG_7r3lGhzCeJDmqhRfE9_xjsyj1z7g8ujZYn0IO6A9tQ7R8JF58CECHv), [14](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQFqOtF_LAtT09DyIIkVVCy1S6wEHTcznkO44ja1IX3u6yWQBJq5LzvXtQa6NvhVFoQDR1OvxSOz8fH5_hD3ad2XgEhtPV_YWdzM8t6gWwywuzR8fSSFputmIfdqNKk1LtMCLE4i4XrugPKmzUAVAhDBvi9xKVBdnZSO2Xnf-qC_SL9rFaw=), [15](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHp-FLQQQdS4H6EdZtBH6jj_CUx96MpqyoNt6Xr7M3egeclm2mOUg1NxBCfIoTXnv69tSdCSbnp-Hp5Wagri9EBOupTiSTlkrajdlUY-ppVMz-nA6SbR2BWaKCGWNYAngGPHnjhzBHEheOcJfE=) " ;
    mtr:llm_phenotype_driver " Gene-centric:FADS1" ;
    mtr:llm_ratio_evidence " metabolites not in a pathway but enzyme catalyzes one metabolite " ;
    mtr:llm_ratio_explanation " The ratio reflects FADS1/FADS2 desaturase efficiency, balancing the incorporation of specific unsaturated fatty acids into distinct complex lipid classes: sphingomyelins and GPIs.[8](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQG8gnnGZDef9bG3MtAb6IDCfZ6DxEu2ZR4cDm9BoY83KdV_qLBfoNdIfoRsJh9TUlwv11Mc8bXb3e-Zd9PsZJHK56BSGtyD868miXFOUNMK1XIxP8kH22q4JGf-FmMjMIPJmgsFjbfJwdNXVQBNvxfl9Dix6izMMW3QzgWk-NUWK66WPWkKZqjOGKRx9xU_g-CNGwvOidC1VMH5yGEPtTMgMiUelJbcvO7BwJ71bSIqHa-hmyM1GaUlgXM7DKCE3tobx36Bb2HwM4-If08=), [3](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQFEsSKnppssDhrFcsUHVjY4d-uBuIuo8o6hye3vkVXpjb6b7Y60V_OlyVIlDi944MT8idIUF85SAILJKgawAY3y-vZvOjesYe7a8DdUYsf4FY_3zldnkHdnH_4nXf4zmmL6KxJsLJSX81hZM9OQ_bX57kU9jXr7yGjszvUe0W_QQwIlGxM=), [9](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHkbxxPVOgSZEim6Bz799zwtakVpme1ye8l1zsSgZuJtwi2HpNwIY96rof9xx3OtdEtTF0xxxUA3Z0geejOHxjR3Cts0422O_gQ32e7QeBK7hbgZUCogmuG_14YlWCmPb1fE-wNb0qDwmWXv5y19xA-EQ==) " ;
    mtr:max_pgain "27417540722.10988"^^xsd:float .

