    mtr:has_denominator chebi:16857 ;
    mtr:has_numerator chebi:18050 ;
    mtr:llm_gene_phenotype_relationship " Reduced GLS2 activity may alter glutamine metabolism, affecting hepatic ammonia detoxification and urea synthesis (BUN), and influencing inflammation (CRP), and liver function (Albumin, TBil).[9](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQG3WBBme_ZZA-Zo2yCihSBz8_8utwFOKK0m_qSDpfK74DEgGnq3Yut0NCHB3VHSBY5DUsHjo4LJZskLnFa2aHdhwkK6aqQa6bMflXcYtEKoyGeQsPTc6NSL3C78HrYGtB0vq39SX1oRAZtizow=), [10](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGUHaezwGJvILX1SHemhJaEuidT96og8u9gO1EPtTUil8F-GgZR9FjBKyo3iHTTX3d73rdTVS-GiHlHG5DF2yIQ4eTF6ukGCuLgd8cSbCwLJJNz2YUihbWWQzGMbky7kbrag1QHdJmTHR9khRKtF-kDJpeIBHNwnQ4XcBRPdh51osegMrI=), [11](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGEl3c8KPiPM5t_53qyf7MgO7IdV3bWHpWwajYeVXz4tIhuMiI7Br-Jb6EZhelWdZaQNsHRInNEFpgHDULX5N5T25gzGFBJVBHLg8F2AB3LP2VCA36z2vrePySMUqX7zCjOyHwjyxkUs0YNtR99Tg8bOAdihPzpBRf0sJgco7h0S9j1RDdIQ2ecj70THLXcve_L2EDR2BJaz2olzKYDdjVY7ZfA1MzX6OhTQNzOXUhB9Umrfy9Z4nz6j3hdXUIXe1kuY2Y4Hw==), [12](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGH27mv4n7eh8Et-VgLt3OT3QtvLwM405JCWd07kY_uZ5mqqja8UsmB3KsSRlFLO_9uTJ3eKhsqonVDonvGB_zyDLk9LWjBMZd-ytpsU4ZJAu2Jx2A6nT41cDJkigtBkS45qFmVc3d8CBVKvQ5jUg_nuEfAqQ==) " ;
