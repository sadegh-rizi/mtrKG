mtr:GCST90200088_GCST90200450 a mtr:MetaboliteRatio ;
    rdfs:label "(s)-3-hydroxybutyrylcarnitine to caproate (6:0)" ;
    mtr:has_denominator chebi:30776 ;
    mtr:llm_gene_phenotype_relationship " Genetic evidence (pQTL, MR) strongly implicates ACADM variants in altering this fatty acid oxidation ratio, reflecting metabolic efficiency. No associated phenotype was provided for analysis. " ;
