mtr:GCST90200246_GCST90200031 a mtr:MetaboliteRatio ;
    rdfs:label "3-hydroxydecanoylcarnitine to nonanoylcarnitine (c9)" ;
    mtr:has_denominator chebi:70997 ;
    mtr:llm_gene_phenotype_relationship " none " ;
    mtr:llm_phenotype_driver " none" ;
    mtr:llm_ratio_evidence " reaction where the ratio is shared through a pathway " ;
    mtr:llm_ratio_explanation " This ratio reflects altered medium-chain fatty acid oxidation.[6](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEdOkvOvt_WJuxywruIxRG0nc0HYH-K-uptp8N4WaaOsd204c5Y4QyNRBGje9CiU-Q0o0UMtLW9z2NKteTXuKxYzGRNoHBm587stDX8zrjn5mcs_XotM4DGLGIKuaZED4_alxrZlPY=), [4](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQFe1c59dihC3bwoEn2bXNIINSuCxO6yHevXzDsVJZIhI70zYx2xNORem5TNJ3_44HoitT9xQq0cc-w1ZCz0l-P0QZSxFTz_-76ZHqoh0uohOIDZFnQEq476H-bkluFKHVFXlfGb3QpfKDZ9Kfw7AIWdPL9c9z6R4EBZh4aoQizgDOaswtLXR6XXFeabqZJ-QKz8AvLGR8lqY36z2fGcHLHc) Reduced ACADM function can lead to accumulation of substrates and their byproducts, affecting this ratio.[6](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEdOkvOvt_WJuxywruIxRG0nc0HYH-K-uptp8N4WaaOsd204c5Y4QyNRBGje9CiU-Q0o0UMtLW9z2NKteTXuKxYzGRNoHBm587stDX8zrjn5mcs_XotM4DGLGIKuaZED4_alxrZlPY=) " ;
    mtr:max_pgain "1.543723180945188e+21"^^xsd:float .

mtr:GCST90200332_GCST90200043 a mtr:MetaboliteRatio ;
    rdfs:label "1-palmitoyl-2-linoleoyl-gpi (16:0/18:2) to 1-palmitoyl-2-docosahexaenoyl-gpc (16:0/22:6)" ;
    mtr:has_denominator chebi:74963 ;
    mtr:has_numerator chebi:73212 ;
    mtr:llm_gene_phenotype_relationship " Reduced FADS1/FADS2 activity, indicated by an elevated ratio, alters the balance of omega-6/omega-3 fatty acids. This dysregulation of lipid mediators can contribute to inflammatory conditions like asthma and IBD, and metabolic disturbances such as hypercholesterolaemia and type 2 diabetes.[2](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEe-9fxkTWPym3Axa73jTdxDKBG8EeASE8E3mA9OwJZ53JsFpk1OueV3LEkHqOjZw03O3fsLWsWxZ5tasxaFL8MBNnp64IG89XchqrqMYBAYxNxHIX_), [9](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHziHCtXpNYmmTDcHYPK2MwwMHJAEmX-ZIOZ_CWPaUxd6Y0oJAk7L30wdvypvf0yIpTxODgcKgR8LhnkDewAaW4g4SvurRUZRnJ8d0egZ60XKG-jwsXdjnJVbLVEafs91x2MuzutrHRqadWKEBtk_HJIauO4oX4Ab8WQpNiJod8LAwyVElsx1tU0hbaFSrfW7vC), [10](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHlnwPSUeUxg98Zr_4pJEmcCCkW-9tb9diunpgvOC-xcpgX-65QbEjnAImLdT3CLsbKAy_hPc-f5sbc1GQSjJFtJaXRxZHskBXTkFUshNJbqCW7CXApntTP-yBCe_MaWJ9Ux2Bd62C8f6Uf0pQ=), [11](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQERRu1wlOZRVsP4C33zBOSI6Kn8gp6EGyLk-joga3ar4g8SDExsuy5iV0DMW2geudGocuASRg38oGwuZDSi_hlDyLtK90JTAMla3t4AYWgiyc-tI7nJU9-ISeC54A07TJ_kqJ8jDRexMCWsfl6Y8XaepJ1eZcoX8Mr-7fpfqbEtmkaZs8oLvtssQW8YnoWu6bY=) " ;
    mtr:llm_phenotype_driver " Gene-centric:FADS1/FADS2" ;
    mtr:llm_ratio_evidence " reaction where the ratio is shared through a pathway " ;
    mtr:llm_ratio_explanation " The ratio reflects FADS desaturase efficiency, where a higher ratio suggests reduced conversion of linoleoyl (18:2) moieties to more unsaturated downstream fatty acids like docosahexaenoyl (22:6).[1](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQFmC7vkT0p4B2ioSo4g8lCIF1W7Ffr_ua8Mm3_JejXgwhCCl-3vsBb54FEBIJlTWVdlha6B6190sSK0LSJ9gRnT0FeTZl2kZoiduCVsHnC9nFEPmc1HVqs16rMsga2EkolJmgHjnpngCDwTtUY=), [8](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQFamy0PxcZcw92NoF3nrMM-yAn_6zxE2Y9oMlfd0ugVtob0PPXO8lgv5TJ2HEdALUobb7f-YGDZrR61Wa1TJ2XvA0n9lXuNC_4PPt9Dkd4VYfg8Rads1by6jJfOwyzSaPhcyXD3FBsvd7r6wYM=) " ;
    mtr:max_pgain "5.243035857583137e+20"^^xsd:float .

