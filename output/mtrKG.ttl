mtr:GCST90200088_GCST90199723 a mtr:MetaboliteRatio ;
    rdfs:label "(s)-3-hydroxybutyrylcarnitine to 5-dodecenoate (12:1n7)" ;
    mtr:has_denominator chebi:86595 ;
    mtr:llm_gene_phenotype_relationship " none " ;
    mtr:llm_phenotype_driver " none" ;
    mtr:llm_ratio_evidence " metabolites not in a pathway but enzyme catalyzes one metabolite " ;
    mtr:llm_ratio_explanation " Reduced ACADM activity can impair the oxidation of medium-chain fatty acids like 5-dodecenoate, potentially leading to the accumulation of upstream byproducts like (s)-3-hydroxybutyrylcarnitine.[6](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEYXeo__2quoOCGbPiM_kImCbpb28x-zPIBEc7opdIk44JrMwqBuKGRNRqm_0Gj9efL5xE70WqejwmSKeGol1wxWD6tyQkHM8tP6FNiz1Z7BYTM4qw53m8WwvaiA6leb9IDxkDIgdTG), [7](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHyw_ga84H_Uu85x8p_AyGXPO9idw9QnW5yqDUAe5D7_ctmC1i15ndA_x2pgPm70NnsHimdkGemQY4vnenW8vqPAEriA72uk4pQTZia2S60NKS3gAUs0bWxBaSRyEyh0pH4fmNe3A==) " ;
    mtr:max_pgain "473946752.7481354"^^xsd:float .

mtr:GCST90200266_GCST90199971 a mtr:MetaboliteRatio ;
    rdfs:label "cis-3,4-methyleneheptanoylcarnitine to 3-methylglutarylcarnitine (2)" ;
    mtr:llm_gene_phenotype_relationship " Reduced SLC22A1 function may alter hepatic carnitine and acylcarnitine levels, impacting fatty acid oxidation and contributing to dyslipidemia and increased ischemic heart disease risk.[3](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGp52sRiu0rctzI7CsxHEUarxcrh7xbAPBfatOjrHJpULnYyiCOEQsRIcdiTf3mUmHK5MVIRLJG9WmJFBZlyXBHcjrtIAuNB0F4HLEERLYfSYcaQ2Hx-8NIBglct5HK6-Yu7dWLb5HYquHq5o-m0DAXvNcMJMz2tUCgN9y0ZHj-e5FFPZvhzaLE), [4](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHQKRcWIubSLdZkscYV74Vo7PGf-myOVAnNnzil1DmPzYTk2l6BkorSlLMGZmsDC_ky0VzWSh4S7-CGcjc0P_eUc6By2SM5AJGNC-BLoNwTqpCY5XsXvb8NAfcMitXV1tMPb2L1f8Bm55wiF_OC53zhg4LjzQIVMLfT_DQjWLpI8bUozTe-WJXYWzFiUg5WZDyirT4Q0NjrYFXQU21V470G9CCVstfZXzec4eZl9FnQUdHcp89xEvZLmYnjuHE=), [7](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHUO5nmSr7u8ubQxmBOHeDiWTpJbjmICC5Xnb9rxK8Akn4t96_4p5vIoNC51s8fgfKChzAm6uBWVYU9cp73LqlNRnZCbhVdIFjCmBhNx_vQ37h8_quz2KYPurEdvcLb1rWpq6nJ) " ;
    mtr:llm_phenotype_driver " Gene-centric:SLC22A1" ;
    mtr:llm_ratio_evidence " metabolites not in a pathway but enzyme catalyzes one metabolite " ;
    mtr:llm_ratio_explanation " An elevated ratio suggests altered mitochondrial fatty acid oxidation, potentially influenced by SLC22A1-mediated transport of carnitine derivatives.[6](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQH9t-OP4C3ZBq-63wGhbH2BVxJ-XfiJ-RKJderziDA4heba_-4blxY5D7STW5bZQSILXPWH_k2rhLKuhV7H3TL50VP4vuvoWhBt3BSaENrZzdu5EINirOjkXyG5LAi6LtEZWWKktxYmqVs=), [13](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQFQ82Oaw9tlWS9LG03ta-TZ-Z6kZu1MJ5tFEmW17y2bN0wCzM9iq9xfwhfGwi-QktGXS1hYaZ_cwqbe2EuFelH2yJGC5Kmud3T1Ij9X1ZJKTtsOOtVuZypqk1fOaJiXpvDLdyln) " ;
    mtr:max_pgain "3.981976975822213e+18"^^xsd:float .

