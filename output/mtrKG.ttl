mtr:GCST90199995_GCST90200046 a mtr:MetaboliteRatio ;
    rdfs:label "sphingomyelin (d18:1/20:2, d18:2/20:1, d16:1/22:2)* to 1-stearoyl-2-docosahexaenoyl-gpc (18:0/22:6)" ;
    mtr:has_denominator chebi:84829 ;
    mtr:llm_gene_phenotype_relationship " FADS1/FADS2 genetic variation alters PUFA synthesis, reflected in the ratio, which impacts cell membrane composition and inflammatory precursors.[8](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQERD9kTHKkkZh8BjXRFKonEWY-NJ3CPu-0VhMb_MjpWInoP6q_73ymLEueUi2QyTrH4KYqHVQmulUYVquz9kCsflH2l6VYgEM6c2VsDdp9xNnGa69usHQOxL39b3s7ieAHX6Yw=), [9](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQF3lR08OnhEpUiOn7c9tcSw0OjxNwZ2oohg9M5hQL30b71tBU87N32mYgH1SKDk_EMmGRMdSdScrru9_BVD1ceL12U-7_HC5OFxfoCztTGmbRVIiTr5kvZaeFNYEckDhGBAtFf58C65i5vJrA==), [10](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEb74Kn_WmAREYa6gtQQIXnCyVkWrg4wX5uteZhmiDD2AyUj0wrixEDZ_aBYGvjFee3bkwEbGCK8g5r4lwXUOGVLong586Se6BQYYwnAGY5FUOBR74aYcE8alInN2dTNVPeRrfF-Vw5RDH5mbH-v8mwfBN5Tc6eofXxmeyTOGlfRvDoPQ==) This contributes to phenotypes like dyslipidemia, cholelithiasis, and type 2 diabetes, which are strongly associated with altered lipid metabolism and inflammation.[11](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGAZM7_02QltldbyCEWCPhRnoxGZTWGKEkMVLCLz0FCgNumK6AkZ0Woo5ZDv6qS4DEz9fLHAAEsw2wtMojj4bWZBUrEBH1AthpnL7TkYditzquZk80jHwpAXnW_0w8SxE-CMtoTdxOSJnyxKiiOYPq8WKYs7w==), [12](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGJikBICsMfjdXC5wr2EeqrOdDIJTaV8jyHE05N8jcglBkjLO9Yj8LkOV89hDKgSD49Xp-BVw2dl_dmehNdzGXf2gW6J0iFAQQRDpUcRohaVg5WoM4xNXzN2dO9Ui4XVUN9Jk905kDZTyLf7g==), [13](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEfKrbsDIoFYZE9M5r7rLZKajBs9CtAdOj6jFs3hRciJJJDH10CgJgmcS0xdBkpg_bD7uBELeXMBlwP4yB8U1jj38OEuqWHSotaIdcsNo4S3_93urT2igGddW7A6sig3anLONuvRVsnUN_23lT8FS0=) " ;
    mtr:llm_phenotype_driver " Gene-centric:FADS2" ;
    mtr:llm_ratio_evidence " reaction where the ratio is shared through a pathway " ;
    mtr:llm_ratio_explanation " This ratio reflects FADS2 activity, which influences the balance of long-chain fatty acids incorporated into sphingomyelins versus DHA-containing phosphatidylcholines.[6](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGD0hOYDacnVrdgjc7moY6lKg900c4fDZ-5rWM5dr8aDFnKQjXdHJeyy_Jx-UEtgXryZMiRbbZAoorJxQ8jpL1QION2gIGcXkpPdWMt_Bph73j6vGraHo72PtNgnGk=), [1](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHjavZ-nVcThn6vZcWMxU715LDR3NpVPE94s7c-zaSGjrO3qkAvh7vtrhqVdAUYLr6ULkMPjGvqql1mdC-OHu8lltI8iz3cfoDiAG_EysRJEfc6sJSmOJpuMYKxI4JhYPFuvL3Wp5wFMQ==), [7](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEvfSJT4y8N5wuyuzZin2AGA4u2TOY7I7399qYYEVlrS4EkDKiHfQS-GUfKwJWEbk1dNZ1KVyZtjNLV8xlTX8DUJFg7D7zk9-b3BxNaVwr_zjyaoRi3JU0qGPE3pCai2s3OAfThr5ls0JViw75KfhIVcJFGYzRHv7kjzyYeqEcefuzKUcc1N8b4LTFNvjHaY8E=) " ;
    mtr:max_pgain "3.037053742851626e+33"^^xsd:float .

