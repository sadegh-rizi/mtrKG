mtr:GCST90199718_GCST90199806 a mtr:MetaboliteRatio ;
    rdfs:label "sebacate (c10-dc) to tetradecanedioate (c14-dc)" ;
    mtr:has_denominator chebi:76308 ;
    mtr:has_numerator chebi:41865 ;
    mtr:llm_gene_phenotype_relationship " SLCO1B1 variants alter OATP1B1 function, impacting hepatic clearance of substrates.[6](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQG4xDR3lNuLC-2yrK3UAxU3zEpabCifQ_M4bnwBQ11JMowwKj75B41C2YMgDeU0cLaQyR_qAfsfAzz5YUaQf0nBAwOM2I3bug2gbd9sTHM2hvXbXEK55kU_B1xJkKY9UOTeHg==), [2](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEltHJE0WcEzlUZeF-PBvCHFO7LzJvopWtPi_elBH0Sq1hqX8R9t_cP_JBtxsPEfMrNP-zfqiZSkUL5773iVYvSpuaegZxmxoiz1f5KeEXvdkksforpwJT43LMKbF-RBKaII55ZzTgamgxAU50=) This altered transport can affect plasma levels of various compounds, including dicarboxylic acids and drugs, which is broadly linked to cardiovascular phenotypes and reported drug-induced arrhythmias.[14](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQH8Di0LXN5P6KAhkLE-g_nBrqcCr5LuPhoN7nFpNSktNF27ZLah9HpE3e3o6lmBD8Ue8mfsYPFeK9y5PlJmdhxG0RUUjB5ssH4rKw4752TbxMfBWQQYmL3f1hFZWLdEXkS_0hghrpWwbs4NEbcO97JTLNCyKQg=), [15](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEXhYwxGuQGmjCxsp56N6sNV97xh_frBCvAeDx68WY2X0f0W8l1IuZvtlc-coNyAnYl3dZXKdYZc6bIs7gFHngIV-yzV6DM7x9ABwVi2L0Lzx5wwl-QM8BuvBbNjIbyPxNiAKrrV7Fro5AjCxRCa1SdZxulIKBPgCJWZnNwJ7_J8F9bbdcnqRdyNlHuCwKa3GvtY7SPdwJcwHnEDuGXnQ==), [16](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQH_GwlJtlld364-qJnWMogHZGsFGVoaSpk16gHTw8w9CFzafq9Ds4SVMudiVEFiEntdCu1DSxcFXwD_DbAtvJ_P-cGoDqNghf_JRZwXswy9FDDSxTAOJjVlRiD-UsiQVbk9W8Lr), [17](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGPddtw53kl4GmXQjLYOSVo93xS-Pqkh-y3-g7s5gw8V5oGuwwnOVpC5XMiDN9owCBK2OZoio1gbAuNPhuYCzqG92NEdPraOwBL6ypAMlWLqCRsMgsz5YapGlZDuw9V4ZoukjqekzFRc3TAu_37HCSWqskiPF-8WDOAIm55gg==) " ;
    mtr:llm_phenotype_driver " Gene-centric:SLCO1B1" ;
    mtr:llm_ratio_evidence " metabolites not in a pathway but enzyme catalyzes one metabolite " ;
    mtr:llm_ratio_explanation " The ratio reflects altered hepatic uptake of medium vs. long-chain dicarboxylic acids, as both are substrates of the OATP1B1 transporter.[10](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQF1yzdQUik8yr2y_ElZrS0jdndcztpmgIFjF-dfplNAJZvcEXDzK8FyL2rdCr4Y1GEI0Jtt20-KEYcRl0g1a51l7nXydIxCWJLMD25P5OgQxYPXuGCQ9mSeFoYQmQRtQwWgYaAQ), [13](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHrVRAFdo7NVRThjD5oYLjGgVjQdiJluq0Tbd0x0XlZ9f3UsTuIes9ZBRc3VB44HNmYYA7F_EMyv6TSAp8bxBUaxWhu_49dVr8DUZMl8fWQw5h7CSRKD1OZXanYxorqY6zuDtNTWBBI-FiwedywANsxR7f56NczDDgkZysV453TQlKyH-tEC6BmA9GRIOzsSZsZKpDzONjMw4Gv3nTH-YZgEU5paaPgO-NmdVpp-PO0uQ0ZBUa6hV7eJwAhF0u-W0k=) " ;
    mtr:max_pgain "1.518803260300735e+31"^^xsd:float .

mtr:GCST90199855_GCST90200179 a mtr:MetaboliteRatio ;
    rdfs:label "5alpha-androstan-3beta,17beta-diol monosulfate (2) to glyco-beta-muricholate**" ;
    mtr:llm_gene_phenotype_relationship " PCOLCE enhances collagen synthesis and is linked to inflammation and tissue remodeling.[1](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEAA7pO5RsLCIW7SmUEsO_e-Q3aMaUAU2-BAyhGJytmxjseadC2mPzHCuc7Aa74PK7HwnRWoB4Ltz-SlOlNpAepIKocP88HGormQ-S9zXhZCQtUG6DCbpMsAF-hUhY0RQ==), [2](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGpAHmJ0cvuK-NUaoqKBTNnMaYBTSVlGI7kh5_fARQZU_Db85G-682VyHB0h3C9OkMOCALrgujHj9KfOxTKlxyEJMFq1JwSiBdKnqw4djF48p4MMCeVMapRPjPFNKJldlY0tIoHfVJ_ZGkZG5I=), [7](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQF5IXQEWf6wsdZcdLLA1xN2GsyVpnBXodF5tfFR3JXiz5pgjYjz1BPsu6JS6gMGoIh4QjzRDjH665WlM_F246yUhgPkxpe5NWv0w4o5AbQHsQeLyDOmep6ABuQNYcImUsGJvwX6W1w2VIpPETU8ruTW6nc3LCAaJXqDykmanbYdF8IvEg==) This may influence phenotypes like BMI, height, and inflammatory markers (CRP, WBC count), while its connection to uric acid is less direct but potentially linked to kidney function.[2](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGpAHmJ0cvuK-NUaoqKBTNnMaYBTSVlGI7kh5_fARQZU_Db85G-682VyHB0h3C9OkMOCALrgujHj9KfOxTKlxyEJMFq1JwSiBdKnqw4djF48p4MMCeVMapRPjPFNKJldlY0tIoHfVJ_ZGkZG5I=), [8](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEwdj44laKHkCcDbXgEcN68j8VkZU0cjjAHplvMne9rTGEvrJkuLJuQ8jJka3UpZ1yvPwSRTFJofI5HkTjFgBTVgPZ5k4ICymHhCohNbSyxsT05Wqbp5qBmXoNIzdImXNbdkimGV6PIPmMukVu8bYQB8zbe_qFL0oan9JL9RqFumW4zgCbwqiwnXgL1w5Uomtrb6K3VuE3Gde_A2NzAiAy22qE9poy3CRCfL-jvaHIfzLhhJLkk23dtBWw4mQYBkTk9SnQT0D2Skj7u17M-oX9dk0HttgjDSQfiFsnQEy6yFSc7_YANJ4f0HxHkFRK8n0ErATJ0oRttVP_QoNFRy5qMtIEN1fDxNGMjBdnLOuR1VA==), [9](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQE_WQP4xGXWHMkJqrxRWk424m-LsD_-Zure3Q0Gq4OVPDWg-pcfnHL_-oKWODBdLZJjuzZLbL5NAi7Zd1sB9zuK5PgTXbyxqQL7m4dQLMsj3DDiv9irY21IjSBHS25u0sRDPkICMC1gl7fuvXGT), [10](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHgz2G5Ypb3QxUypHwwwzHZCtUErPvk5qVukfico9seVW2pFyp8iRo74TA_-UE6KyoktIotOEpPHJa1tVtuioSFNnIiPGDCsLf5_vElbowqUCjhu3JUNP0vmyHGAEYhjQUpAPtaZbOI-xf1Hmeg7cag), [11](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHJ_K3j4hvhkl40EE-d2V03KXEge03R5qmsNMz7JPLkDzxgKRCWZOpJgq_mynp0V_fGvaV5eU45FLK2BexGPzF8XyAb3KvnbhhwPr-jhJP0PwBsTXUoLJ_keg87oNWwhq6DQgpYG-WTIzevteYBvpU_S2L9So87ytmAmr-BMLU0cfbOFTkOaD9JSplU_00kQG6PcK848VJbrWH5OETg6flKI80c2wTjbuydL7mkH8yop1t3RSUo5tmJG1VsxndY71XNhFoE6TjQmAhfYRqE3si0C4u_lhwdVYakEdSt06Kzqtr2sYZ7aKrweban-JsHzQ==), [12](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQFsDQIVqvmbVfj7oly2VzTIeJxh3SS4-mFELPG1q8ggiy5U8CAnnIyqeOCkjsdEXJy5K1gUj1z1856Sx5m2VA8zWZ9OBJdGMjCdnxeOgo76GuztxDquEAWT75a-rs0U4EIh57EW4TpLiKH6YITSK1gzHtz8dLXKyx77k5KBK6nfG5t2J6pPKzOl6g==) " ;
