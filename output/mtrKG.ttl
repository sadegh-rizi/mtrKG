mtr:GCST90199923_GCST90199744 a mtr:MetaboliteRatio ;
    rdfs:label "n-palmitoylglycine to eicosenoate (20:1)" ;
    mtr:has_denominator chebi:32425 ;
    mtr:has_numerator chebi:39540 ;
    mtr:llm_gene_phenotype_relationship " Reduced FAAH function due to genetic variants increases n-palmitoylglycine. Altered levels of these lipids are linked to inflammation and metabolic dysregulation, which may contribute to cholelithiasis and chronic kidney disease, conditions with inflammatory components.[10](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEIloYuCWA5J-FCL_1d_RnGdlO5Iu-czfEw-U6Ei_2yZ_rcU2Bl1ABTfO85xjYVa3lTLfMIB3Rw5XmUbmg21rXFckuWHu-cCTD8MSf02BHSK62bsPKK_3XemhULx0lpkXJPOB6zzzXPU3DrCIRA), [11](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEsgIj4Pco6-DNH8P57PJXT4K8cXegZuvtdv32WaoO_bI_eHIrciXCq-CVIEf4VYxYEXKTZIxcZdjeRY7gRe4Z3UGKC3hu0dfbLYZRxPnDoLCegBxdLUJvRsCGOywwuMUFgiLcPaaAxuqFBTvAEuf0OjwZy0HL8AMc8rQUTKNpj5bCBrjKMhMgXm-vWOA==), [12](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGebOScSo666ryOU70ehWmiYHdXqD0hXZeaPf1E9lzf1JYGCwpHxB4F-_V-LukoeI65g0-yAktxQyoU4sDw1KKn5Zywsy-ONfdKTwKXhkbPOy4b_62UUSG9ik2Xml7Uvpdh9sYl) " ;
    mtr:llm_phenotype_driver " Gene-centric:FAAH" ;
    mtr:llm_ratio_evidence " metabolites not in a pathway but enzyme catalyzes one metabolite " ;
    mtr:llm_ratio_explanation " An increased ratio suggests reduced FAAH activity, leading to accumulation of n-palmitoylglycine relative to eicosenoate, potentially impacting inflammatory and metabolic pathways.[8](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHexUaxidgcCcitvLLtOJ0xcJL7FQUSNs7PMFMY6dPaUWSaMzD6LVaH66FVI-Vd7YcXyQVOTRgWIpNwQ70BahEGcSUb80Dtr9CDf4fi1JQ9i9SlLJsA4alRw7kc6i6J_MWaPIxDeutlvtkf300=), [9](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHUL1lq3SeOaOVwcUtoIOD2_wJT_UC4DtVXt2VsmLlICtYBbZ48kDIddvO8dXi5x-xR31uV0r21XW5x3oOG4ve7Qjh6yGNdaOT5CFfcqsV1SW4bwWyyiI0si3b5ldGyfrffEY7ySk_Yzt1BRI244BY=), [10](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEIloYuCWA5J-FCL_1d_RnGdlO5Iu-czfEw-U6Ei_2yZ_rcU2Bl1ABTfO85xjYVa3lTLfMIB3Rw5XmUbmg21rXFckuWHu-cCTD8MSf02BHSK62bsPKK_3XemhULx0lpkXJPOB6zzzXPU3DrCIRA) " ;
    mtr:max_pgain "3.239584364331764e+33"^^xsd:float .

mtr:GCST90200082_GCST90200692 a mtr:MetaboliteRatio ;
    rdfs:label "1-oleoyl-2-linoleoyl-gpe (18:1/18:2)* to 1-palmitoyl-2-arachidonoyl-gpc (16:0/20:4n6)" ;
    mtr:has_denominator chebi:73003 ;
    mtr:llm_gene_phenotype_relationship " Genetic variants in FADS1/FADS2 alter the efficiency of converting linoleic acid to arachidonic acid, affecting the balance of inflammatory lipids and lipoprotein profiles, which contributes to hypercholesterolemia, other lipidaemias, and benign colorectal neoplasms.[7](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQFQijXpAj2evwT2rw6FIRpIGDv1C5EHTAjL_pWYEisTxGE44I_JKuPe4-9ftaaksCashpbnzjz237e_1ceifQqVDlZr29t0qkg-YQrUHTeFWBZOrQ63jbOT4oVbublMpu4z41ah2A6Cmp18uA==), [8](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQF9FHcEHl4yMoP6Hy4kEqrG8ge83xYXCqzFrnBWJTkK7C7MoF2B6oeaBJvLQbI5uxFdVdF9xR76jLM7tsbVdxUcilj-O0g2pCyfSBRwDmEXbtF1ZQJSlE5oyLVYTsy4LERj8D2KzoAsDIGMNBD4ip0k5Htb6v8pRU-y7ipDKjkWUvKkWH58cmYxAbOpWk6lDU6N8WhX_9JpZlAIKA4phEok_3jaw63-XbnqUdvB17LqKowE), [9](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEJBAmRJDhg3oar1Wftj151UUc2AnPWsD82EKx_2VuOF3ACkd9ET-BsWkF5rLZRdj__6o01DbzlzcxEpdltz9bQOq9cB0o8hzItIKVuAz9k-A2yrhSW7dgupLiAhZ4TNJ4kp1gRGZ7ZCT3UkEo=) " ;
    mtr:llm_phenotype_driver " Gene-centric:FADS1" ;
    mtr:llm_ratio_evidence " reaction where the ratio is shared through a pathway " ;
    mtr:llm_ratio_explanation " This ratio reflects the activity of the FADS1/FADS2 enzymes, comparing a phospholipid containing the precursor linoleic acid (18:2) to one containing the product arachidonic acid (20:4). " ;
    mtr:max_pgain "8.1069706881058e+34"^^xsd:float .

