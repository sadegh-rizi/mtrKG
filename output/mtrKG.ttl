mtr:GCST90200039_GCST90200692 a mtr:MetaboliteRatio ;
    rdfs:label "1-stearoyl-2-linoleoyl-gpe (18:0/18:2)* to 1-palmitoyl-2-arachidonoyl-gpc (16:0/20:4n6)" ;
    mtr:has_denominator chebi:73003 ;
    mtr:has_numerator chebi:133599 ;
    mtr:llm_gene_phenotype_relationship " Genetic variation in FADS1 alters polyunsaturated fatty acid (PUFA) synthesis, reflected by the ratio. This imbalance in lipid composition is causally linked to disorders of lipoprotein metabolism, hypercholesterolemia, and cholelithiasis by affecting systemic lipid levels and inflammatory processes.[2](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQG8AGvmP-BtDDQffzQI6co3qjjQ8_81KQbGTCunytGZ6wg_NLFFhegcdoFyI0RwkjryvKieP5DSPHFcqunSG3v8F5lBowqsr7ZxhtnniH15D8ZY9I7WrFnMo4XyGOitBUNEr_CaktoJrIQhXWVssIpgON4fIHZWVd5xXYo6at_xKJzL737sxauLbGErfIHwxyVJw5tjH4nhlFV0IckBMsS1P1yDRNq1r6tXjqkXtnEZHcOF), [8](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQG635wqWkC-uFcbqQCo-ejaKy4Blhk4XJGLYQDQsj49eG-ptComD-b1BWmexT7cSYP0pMvRI6ApPHVgOz5lDuQKuws6Pw3C5wwh3bm8Mk4xExkxEjW38tWI_8FymHPsqhYRSsOWWjMVk423hlDF9qJj8NIc-A==), [9](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGwJNYFgbea4HlfV1khTdRm9pFyh-rrCr4w7fFRkkL9eJBEychia7x8lgEEATDNMKhtBjWFh1Jt6ysrgxXoKinLByKn4ye2n0k-5GWI-V4EUq3V1SgvSiyWMFI5KzpQanlvvx4srt7wUHpLvdHWdSQgg5Tnug==), [10](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQG_Vujjgho233hEFZcdeOAaZNz-eTCbv_vKz6QQrWpBLptDkxcpc1zqkW3ZZV_KWz8UPO4OMYkdliuap5KzvD13KPSpK5gwOhkbp-JkaynK7kMeaOBR8aRKTptBJFnNe73FLkAoZyPtdwilb0vF7KhfT5Fz), [11](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGpdIwYnlWTLkRriryXFz_mxLElgVcNeDE2aZ11a0ghB38AcK9yxNxfZcsJa_1rsoJv9-IClpmefCvkna3kqlV31LU85pJF3fpoQPUd1QiAYteBiy-3nVOMBJWSflSU0e902qfCGX-KruD_ztHWF_yhMHeyOaizMI4XbL8R5xfL_EMicKt9AYBmmKVOxAjBW7ROkw==) " ;
    mtr:llm_phenotype_driver " Gene-centric:FADS1" ;
    mtr:llm_ratio_evidence " reaction where the ratio is shared through a pathway " ;
    mtr:llm_ratio_explanation " This ratio reflects FADS1/FADS2 enzyme activity, comparing a phospholipid containing a linoleic acid (precursor) to one with an arachidonic acid (product) moiety.[1](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQE_4Prp2y4eVY6zbqM5u3oKCSCcuYEjxG1URYMzXUCVufa849rLjQSGumlLBcjJJ1ekchc6Cq8GWN20AbpbkeKRFVcB6gJ87gd-Rp63maMpzNwGjIh9PvKluNjTtDp-YBj7IO2H-cOqmXBWLyINVdvfaPo=), [5](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHy1WrtTsSxu5NBtY7bsZKjFE3J8WUZp0TtJlMWsGsLHxq_RnBhbNXzw0ZRJsJvKNSfeqEfULl7haZ3UeH3fKLQAqIDTZhid5AwqD6E0ZpX9t5LQDbaBsvCSrrEEdDLO1wWJoB_KCjkXuDnAQ==), [7](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHmcZATYRxQjQt9DEtqUK-DQyUa1WjLSFjA_PeF97_70YlUBlgawH96sM79x8XpinXcbMQsgXXFHFDPmppnIxK39-vtje8hu6M4LIJghPiyDFCAO9EIRIN0chM9_r8ZWaCsd246P3oFTCGKuQUy5wont15pRygE-6tSxTmZmKDgOSQDHZhXhosC-ELo39cCEgRky6dB--gbuFtlTdtPYtZv49vO6eOsHKORIF1S5JCfbD0nyeBL_QpiBnrQcasvuSwBT2CGylB5JKP_LWBEn0Ae) " ;
    mtr:max_pgain "4.473886611012277e+19"^^xsd:float .

