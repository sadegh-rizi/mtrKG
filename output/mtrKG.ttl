mtr:GCST90200056_GCST90200121 a mtr:MetaboliteRatio ;
    rdfs:label "sphingomyelin (d18:0/18:0, d19:0/17:0)* to ceramide (d18:1/17:0, d17:1/18:0)*" ;
    mtr:has_numerator chebi:89483 ;
    mtr:llm_gene_phenotype_relationship " Increased SGPP1 activity may elevate ceramide levels.[1](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQFes0jj61g-F9VFix3P06bVUHBoOdwdNZlwgVXHt8WQeNGJ-pRlH65NAetyYRmCB9pkDbd08s_oOM2rf8izJpn6G1bT-uWc86yBWFt05gDj_yNQ3mWFY5aGHOs97W_qvmhQP2crQWOlB8ZHgH0VXnJ6GxfE), [5](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHNKgzZZsKUj6sv_npKToCzZDhN-z3t8xAVgme3GgFvpBYUTwcUk9yhmBJRsdIRj7uGL2sMisxC_EdtnMQqYnHbbwxdiI1M8WcEy-qc8BPg38xGS4ymJYm4eSC8t5sCmIxICGgeQkxkJNq1D3g=) Elevated ceramides are linked to insulin resistance, which can manifest as higher HbA1c and triglyceride levels, phenotypes associated with this ratio.[6](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGpoRh0zmdhJsWi_yBq3s9NFK9cVULpy8NckKdY-9I9QNLD9mvWLXgXK6jpM56DPPhZJ_10TJ96sUFXRomsZUuDRaa8xkoY45YVF2w-KX5VIiSAeu6qhaXryZuemz8QeMEvIVM=), [7](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQH4rqvPZx2rMzDC_yxv3irwic3qhzW5VVUdYy2_a9CIIOm26lFKYmdkGwe1LuYWbRk4D_FT_d1ZuWOV9w_vQfcrrU4ROayakm9KxZUnv0xfUJ9L7eCmMiPKmnwxaa5TjFEQZL8DmCA0MLDBRlVQXbtKKeerxKKReDdImTEHYhwPlaHkHNjx77ldrxvTARRXxfriZuON), [8](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEZEpRfraXRFSj0_3I2K5rCMp8miUP40YJW258uVdDfs25mG4RHGwYgdauIKXu06xz9xSth18kVNvsPsCvLVtVpNMoaS8bZoqI4vIHh2DQpf_lj_4beX7mGlGXZrVCwq7V2zUF0kQ==) " ;
    mtr:llm_phenotype_driver " Metabolite-centric[ceramide]" ;
    mtr:llm_ratio_evidence " reaction where the ratio is shared through a pathway " ;
    mtr:llm_ratio_explanation " The ratio reflects sphingomyelin synthesis from ceramide.[3](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQE7aUEOxVxWsc1yjl8fbWlxPsf1RrODoLIzXDT06VEf1n8LW0744pgzK7-tZgOdsSWb6WMDEIy3jlwsvtBotSpFJNRV5-aP2adRTmj1sK1laLUUdUZwW4dZhS8Ig7jGLJoUqYKqnveourr1uKu6pgpb7Go=), [4](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGGoBKuhAdf2xxraHVBfpJfS-d4eaV3Ds-gb2TovcsMOp0NvdZau1d4qAGfyVZtQT74tNiE0h5C8dJCC24Jht3Oqkzx0tUKj6mBFabKLDge7TqDBCXB7b1znXrmeWGTmvPL) Elevated SGPP1 activity can increase ceramide, the precursor for sphingomyelin, potentially altering this balance.[1](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQFes0jj61g-F9VFix3P06bVUHBoOdwdNZlwgVXHt8WQeNGJ-pRlH65NAetyYRmCB9pkDbd08s_oOM2rf8izJpn6G1bT-uWc86yBWFt05gDj_yNQ3mWFY5aGHOs97W_qvmhQP2crQWOlB8ZHgH0VXnJ6GxfE) " ;
    mtr:max_pgain "164075459.8226211"^^xsd:float .

mtr:GCST90200233_GCST90200661 a mtr:MetaboliteRatio ;
