mtr:GCST90199796_GCST90200414 a mtr:MetaboliteRatio ;
    rdfs:label "docosapentaenoate (n6 dpa; 22:5n6) to myristate (14:0)" ;
    mtr:has_denominator chebi:28875 ;
    mtr:has_numerator chebi:65136 ;
    mtr:llm_gene_phenotype_relationship " Reduced FADS1/FADS2 activity, indicated by an altered ratio, is linked to modified lipid profiles, including cholesterol levels, and an increased risk for hypercholesterolemia, cholelithiasis, and type 2 diabetes.[9](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEjxRTi3lzFFXQa69uf_zyDIKa9LfBO_jiGl0jCPPvF9vWTTSASKO32x1eV_KetLSIlUICZSXSvcdQ0LS3UyPCi_6swkzTPVAIhcdx__slbUyFlqJNNpQN_3UlrPpdFD0QGPw==), [10](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEi_Gox81WOGKMgeHAZDtlFOu1YLr-oNvAy0fHuyPqMf0yWhvKEynFwNetc_hgiFXuo0aQUKJBz0I2QjHM1k5c7GXGfjGL5AUGl0B9GAMybx1FVGfDNJRAuTSxgP9K6yvfprMhfg6Sk22IBRtilGlaY2avoCk2YeVKxKw==), [11](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQFgfmMLeIhKuMizHoHyZpvMCfoc-vgzLZ059jn0pdJ963zXco-Jy7EFcacTKPRp7npqZ-SAIvvCR38smOSAkyDXVGiqKGz2cSw27Ep-dtroECS59vDRD5Zr3v1GOdsfoCGSCS9N), [12](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQGOAmo1rWUw_0tkiiihsRiApGEk2ZwtmNhzl5wRUwwMZyqa6iRr_lDADzK1tZMx9zIgCnbRczMPuu3v5vLXG0rEpkLY1yW9ltU0a3N8GgTlN4FQj-IXCOPijCHODrV2d-YYzu0=), [13](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHjZ3lge41UYVMtPYAenVBNYHusTDF8wbXMeW10UpEaOdjUFnNhT9YVHXAQ8mGwpEfXyZOVPYgiGlLRw4Vb0iW7EheB0hMh5tjoBXzGVno_qwlzQyVM), [14](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHqqBLi3byqT9u69n_MsmgHO7YghZT0WQC78qhVWe7BVBEyZ6N13z8ESfBO7dFMQqPNkm4jhNzZYuQ44SzKdECIcCGRK8b4D8r6Xsg3TfyE6DXHYzjWn_ejPEVBx2AiDD51Jsg33DvYrG9QJ74=), [15](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEzc-0kXc0Fv2YHZ5R50wxmHWDV_aVImJgWsylardSDIECtV0zpvKursfJ3eK0-cHLpIBZA7jmCDGnTtJVzSk_-24vSg-el6MLPn8gHcUPIL5YRFhwn91PKyJitzPoVDpTE9cgxjdDaHS9gkCM=) " ;
    mtr:llm_phenotype_driver " Gene-centric:FADS1/FADS2" ;
    mtr:llm_ratio_evidence " reaction where the ratio is shared through a pathway " ;
    mtr:llm_ratio_explanation " The ratio reflects the efficiency of converting shorter-chain fatty acids to long-chain polyunsaturated fatty acids, a process catalyzed by FADS enzymes.[3](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQHnvgMLeFsYss_H2sCMUclOF4zxutS5-jYiS7uOLxsi7IAgP3lgcvsWAoKK1VZNx2yOFieMSkPu_L4VJpZIku3Xc9kEu2qOpMThDPCbP5GGxpspHpXMLgDaPYdoDNW_p-gQtCUI), [4](https://vertexaisearch.cloud.google.com/grounding-api-redirect/AUZIYQEL4t4yik1Hr7WWRBbF6jZMreBG4Z91TeQzT9i2f-N6qaf6H0KrCOnIw2uhsGYwVkeqXmTqGShxK900TlPM0yyVNk4mlQGwBKxbs_eWFpgJySvAd_MI0F7kKhNAYkP421FK_QcA) " ;
    mtr:max_pgain "21839934.72846344"^^xsd:float .

mtr:GCST90200030_GCST90199770 a mtr:MetaboliteRatio ;
